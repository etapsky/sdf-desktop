<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Merged into the app bundle Info.plist. SDFDocument.icns is bundled via bundle.resources. -->
  <!-- Aligns with sdf/tooling/os-integration and Homebrew SDFDocument.icns usage. -->
  <!-- CFBundleTypeIconFile is required for Finder to display the custom document icon.
       Tauri v2 does not support 'icon' in fileAssociations, so we declare it here.
       This entry is merged with Tauri's auto-generated CFBundleDocumentTypes. -->
  <key>CFBundleDocumentTypes</key>
  <array>
    <dict>
      <key>CFBundleTypeName</key>
      <string>SDF Document</string>
      <key>CFBundleTypeExtensions</key>
      <array>
        <string>sdf</string>
      </array>
      <key>CFBundleTypeIconFile</key>
      <string>SDFDocument</string>
      <key>CFBundleTypeRole</key>
      <string>Editor</string>
      <key>LSHandlerRank</key>
      <string>Owner</string>
      <key>LSItemContentTypes</key>
      <array>
        <string>com.etapsky.sdf</string>
      </array>
    </dict>
  </array>
  <key>UTExportedTypeDeclarations</key>
  <array>
    <dict>
      <key>UTTypeIdentifier</key>
      <string>com.etapsky.sdf</string>
      <key>UTTypeDescription</key>
      <string>Smart Document Format</string>
      <key>UTTypeConformsTo</key>
      <array>
        <string>public.data</string>
        <string>public.archive</string>
      </array>
      <key>UTTypeTagSpecification</key>
      <dict>
        <key>public.filename-extension</key>
        <array>
          <string>sdf</string>
        </array>
        <key>public.mime-type</key>
        <array>
          <string>application/x-sdf</string>
        </array>
      </dict>
      <key>UTTypeIconFile</key>
      <string>SDFDocument</string>
    </dict>
  </array>
</dict>
</plist>
