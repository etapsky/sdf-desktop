{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Etapsky",
  "version": "0.1.0",
  "identifier": "com.etapsky.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Etapsky",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "trafficLightPosition": { "x": 12, "y": 20 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "category": "Productivity",
    "shortDescription": "Smart Document Workstation by Etapsky",
    "longDescription": "Produce, read, sign, and sync SDF (Smart Document Format) documents natively on macOS and Windows. Built by Etapsky Inc.",
    "copyright": "Copyright (c) 2026 Yunus YILDIZ",
    "externalBin": [],
    "createUpdaterArtifacts": true,
    "resources": {
      "icons/SDFDocument.icns": "SDFDocument.icns",
      "icons/SDFDocument.ico": "SDFDocument.ico"
    },
    "fileAssociations": [
      {
        "ext": ["sdf"],
        "name": "SDF Document",
        "description": "Smart Document Format file",
        "mimeType": "application/x-sdf"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFDNEY5QTEzNTM4Qzc3MEUKUldRT2Q0eFRFNXBQckttVDdjZjVvbU40YjM3SUkyRU92ZkwvN0ZzV05iNThMc3IwWXJ5cnhKQlQK",
      "endpoints": [
        "https://github.com/etapsky/sdf-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
